# Neon Postgres
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# NextAuth v5 (Auth.js)
AUTH_SECRET=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Vercel AI Gateway (Google Gemini)
AI_GATEWAY_API_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# JoJAPI / camgoz product price API
CAMGOZ_API_BASE=https://camgoz.jojapi.net/api/external
JOJAPI_KEY=

# Maliyet için camgoz'a sadece bu marketlerden fiyat istiyoruz (API 45+ market destekliyor).
CAMGOZ_PREFERRED_MARKETS=A101,Şok Market,Migros,File,Hakmar,Macro Center,Onur,Bizim Toptan,Özdilekteyim

# Cloudflare R2 (fiş görselleri)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sepetiq-receipts
# Public base URL — özel domain (https://receipts.example.com) ya da R2 public bucket URL.
# Sondaki "/" olmadan, key bu base'in altına eklenir.
R2_PUBLIC_BASE_URL=