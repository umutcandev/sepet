# Neon Postgres
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# NextAuth v5 (Auth.js)
AUTH_SECRET=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Vercel AI Gateway (Google Gemini)
AI_GATEWAY_API_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Marketfiyati (TÜBİTAK + Ticaret Bakanlığı)
# Kullanıcı konumu yoksa kullanılan fallback koordinatlar
MARKETFIYATI_DEFAULT_LAT=41.064950
MARKETFIYATI_DEFAULT_LNG=28.983262
MARKETFIYATI_DEFAULT_DISTANCE=10

# Cloudflare R2 (fiş görselleri)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sepetiq-receipts
# Public base URL — özel domain (https://receipts.example.com) ya da R2 public bucket URL.
# Sondaki "/" olmadan, key bu base'in altına eklenir.
R2_PUBLIC_BASE_URL=

# /api/cron/purge-archived
CRON_SECRET=

# Polar (abonelik / ödeme)
# Organization Access Token (Polar Dashboard → Settings → Developers)
POLAR_ACCESS_TOKEN=
POLAR_SERVER=production
# Webhook endpoint secret (Polar Dashboard → Settings → Webhooks → endpoint)
POLAR_WEBHOOK_SECRET=
# Pro ürün ID'leri (Polar Dashboard → Products)
POLAR_PRODUCT_ID_PRO_MONTHLY=
POLAR_PRODUCT_ID_PRO_YEARLY=